generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdType {
  RECURRING
  EVENT
}

enum MemberRole {
  ADMIN
  MEMBER
}

enum SplitType {
  PERCENT
  FIXED
}

enum Locale {
  en
  sv
}

enum CurrencyCode {
  USD
  SEK
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  locale       Locale   @default(en)
  createdAt    DateTime @default(now()) @map("created_at")

  memberships       HouseholdMember[]
  createdHouseholds Household[]         @relation("HouseholdCreator")
  expensesPaid      Expense[]           @relation("ExpensePaidBy")
  expenseSplits     ExpenseSplit[]
  recurringPaidBy   RecurringExpense[]  @relation("RecurringPaidBy")
  recurringOverride RecurringSplitOverride[]
  settlementsFrom   Settlement[]        @relation("SettlementFrom")
  settlementsTo     Settlement[]        @relation("SettlementTo")

  @@map("users")
}

model Household {
  id            String        @id @default(cuid())
  name          String
  householdType HouseholdType @map("household_type")
  currency      CurrencyCode  @default(USD)
  inviteCode    String        @unique @map("invite_code")
  createdBy     String        @map("created_by")
  createdAt     DateTime      @default(now()) @map("created_at")

  creator            User                 @relation("HouseholdCreator", fields: [createdBy], references: [id])
  members            HouseholdMember[]
  categories         Category[]
  expenses           Expense[]
  recurringExpenses  RecurringExpense[]
  settlements        Settlement[]

  @@map("households")
}

model HouseholdMember {
  id                   String     @id @default(cuid())
  householdId          String     @map("household_id")
  userId               String     @map("user_id")
  defaultSplitPercent  Decimal?   @map("default_split_percent") @db.Decimal(6, 3)
  role                 MemberRole @default(MEMBER)
  joinedAt             DateTime   @default(now()) @map("joined_at")
  leftAt               DateTime?  @map("left_at")

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@map("household_members")
}

model Category {
  id          String   @id @default(cuid())
  householdId String   @map("household_id")
  name        String
  budgetLimit Decimal? @map("budget_limit") @db.Decimal(12, 2)
  color       String   @default("#6366f1")

  household         Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  expenses          Expense[]
  recurringExpenses RecurringExpense[]

  @@unique([householdId, name])
  @@map("categories")
}

model Expense {
  id           String    @id @default(cuid())
  householdId  String    @map("household_id")
  title        String
  amount       Decimal   @db.Decimal(12, 2)
  categoryId   String?   @map("category_id")
  paidBy       String    @map("paid_by")
  date         DateTime
  splitType    SplitType @map("split_type")
  recurringId  String?   @map("recurring_id")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  household Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category?         @relation(fields: [categoryId], references: [id])
  payer     User              @relation("ExpensePaidBy", fields: [paidBy], references: [id])
  recurring RecurringExpense? @relation(fields: [recurringId], references: [id])
  splits    ExpenseSplit[]

  @@index([householdId, date])
  @@index([recurringId])
  @@map("expenses")
}

model ExpenseSplit {
  id         String   @id @default(cuid())
  expenseId  String   @map("expense_id")
  userId     String   @map("user_id")
  percent    Decimal? @db.Decimal(6, 3)
  amountOwed Decimal  @map("amount_owed") @db.Decimal(12, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@map("expense_splits")
}

model RecurringExpense {
  id          String    @id @default(cuid())
  householdId String    @map("household_id")
  title       String
  amount      Decimal   @db.Decimal(12, 2)
  categoryId  String?   @map("category_id")
  dayOfMonth  Int       @map("day_of_month")
  paidBy      String    @map("paid_by")
  splitType   SplitType @map("split_type")
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  active      Boolean   @default(true)

  // Periodic "is this still accurate?" check, independent of the user-facing
  // endDate — surfaced lazily in the UI, never via a background job.
  lastConfirmedAt      DateTime @default(now()) @map("last_confirmed_at")
  reviewIntervalMonths Int      @default(6) @map("review_interval_months")

  household Household                 @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category?                 @relation(fields: [categoryId], references: [id])
  payer     User                      @relation("RecurringPaidBy", fields: [paidBy], references: [id])
  overrides RecurringSplitOverride[]
  expenses  Expense[]

  @@index([householdId, active])
  @@map("recurring_expenses")
}

model RecurringSplitOverride {
  id          String   @id @default(cuid())
  recurringId String   @map("recurring_id")
  userId      String   @map("user_id")
  percent     Decimal? @db.Decimal(6, 3)
  amountOwed  Decimal? @map("amount_owed") @db.Decimal(12, 2)

  recurring RecurringExpense @relation(fields: [recurringId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recurringId, userId])
  @@map("recurring_split_overrides")
}

model Settlement {
  id          String   @id @default(cuid())
  householdId String   @map("household_id")
  fromUserId  String   @map("from_user_id")
  toUserId    String   @map("to_user_id")
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime @default(now())
  note        String?

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  fromUser  User      @relation("SettlementFrom", fields: [fromUserId], references: [id])
  toUser    User      @relation("SettlementTo", fields: [toUserId], references: [id])

  @@index([householdId])
  @@map("settlements")
}

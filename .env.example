# Postgres (used by both docker-compose and Prisma)
POSTGRES_USER=splitly
POSTGRES_PASSWORD=splitly
POSTGRES_DB=splitly
POSTGRES_PORT=5432

# Prisma connects to the `db` service by its compose network name
DATABASE_URL=postgresql://splitly:splitly@db:5432/splitly?schema=public

# NextAuth
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-generate-a-real-secret

# App
APP_PORT=3000
